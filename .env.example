# MCP Unified Agent System - Environment Variables
# 
# [SECURITY NOTICE]
# 1. Copy this file to .env and fill in your actual values
# 2. NEVER commit .env to version control
# 3. Rotate credentials regularly
# 4. Use strong, unique passwords for production
# 5. Prefer one centralized secret file for the whole workspace
# 6. Optional: export MCP_SECRETS_FILE=/absolute/path/to/centralized.env

# ============================================
# PostgreSQL Database Configuration
# ============================================
POSTGRES_USER=your_username_here
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_SERVER=localhost
POSTGRES_DB=mcp

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# RabbitMQ Configuration (for Distributed Mode)
# ============================================
RABBITMQ_DEFAULT_USER=mcp_user
RABBITMQ_DEFAULT_PASS=super_secret_password_change_me

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO

# ============================================
# Optional: Security & Performance
# ============================================
# MAX_WORKERS=4
# REQUEST_TIMEOUT=30
# ENABLE_METRICS=true

# ============================================
# MCP Proxy Configuration
# ============================================
# MCP Proxy config (optional — defaults to project root/antigravity-mcp-config.json)
# MCP_CONFIG_PATH=/path/to/your/antigravity-mcp-config.json

# ============================================
# Shared AI / Integration Secrets
# ============================================
# OPENAI_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_WEBHOOK_SECRET=
# RABBITMQ_URL=amqp://user:password@localhost/
# JWT_SECRET=
