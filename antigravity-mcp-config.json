{
  "mcpServers": {
    "mcp-unified": {
      "command": "bash",
      "args": [
        "/home/aseps/MCP/mcp-unified/run.sh"
      ],
      "env": {
        "PYTHONPATH": "/home/aseps/MCP/mcp-unified"
      },
      "description": "Unified MCP Server (Intelligence + Execution + Memory)",
      "tools": [
        "list_dir",
        "read_file",
        "write_file",
        "run_shell",
        "memory_save",
        "memory_search",
        "memory_list",
        "create_workspace",
        "cleanup_workspace",
        "create_plan",
        "publish_remote_task"
      ]
    },
    "rust-mcp-filesystem": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--entrypoint",
        "mcp-server-filesystem",
        "-v",
        "/home/aseps/MCP:/home/aseps/MCP",
        "mekayelanik/filesystem-mcp:latest",
        "/home/aseps/MCP"
      ],
      "description": "High-performance Rust-based Filesystem MCP Server"
    }
  },
  "defaultServer": "mcp-unified",
  "autoStart": true
}