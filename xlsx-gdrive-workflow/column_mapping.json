{
  "_description": "Mapping konfigurasi kolom dari data ekstraksi arsip ke spreadsheet GSheets",
  "_version": "2.0.0",
  
  "spreadsheet": {
    "id": "18H6gIv61XTdUsA7zh0XoQqmRWQxlfuNvbRMq5n8AwRM"
  },
  
  "column_mapping": {
    "A": {
      "field_name": "doc_id",
      "column_header": "Boks",
      "transform": "direct",
      "description": "ID dokumen dari nama file asli (tanpa ekstensi)"
    },
    "B": {
      "field_name": null,
      "column_header": "",
      "transform": "empty",
      "description": "Kolom kosong (tidak digunakan)"
    },
    "C": {
      "field_name": null,
      "column_header": "KODE KLASIFIKASI",
      "transform": "constant",
      "value": "000.8",
      "description": "Kode klasifikasi arsip (konstan)"
    },
    "D": {
      "field_name": "nomor_surat",
      "column_header": "NOMOR SURAT",
      "transform": "direct",
      "description": "Nomor surat dari hasil OCR",
      "validation": {
        "required": true,
        "max_length": 50
      }
    },
    "E": {
      "field_name": "uraian",
      "column_header": "URAIAN",
      "transform": "direct",
      "description": "Uraian/judul dokumen dari OCR (misal: SURAT PERNYATAAN TANGGUNG JAWAB BELANJA)"
    },
    "F": {
      "field_name": "extraction_date",
      "column_header": "KURUN WAKTU",
      "transform": "date_format",
      "format": "%Y-%m",
      "description": "Tanggal ekstraksi dalam format YYYY-MM (tahun-bulan saja)"
    },
    "G": {
      "field_name": null,
      "column_header": "",
      "transform": "empty",
      "description": "Kolom kosong (tidak digunakan)"
    },
    "H": {
      "field_name": null,
      "column_header": "",
      "transform": "empty",
      "description": "Kolom kosong (tidak digunakan)"
    },
    "I": {
      "field_name": null,
      "column_header": "",
      "transform": "empty",
      "description": "Kolom kosong (tidak digunakan)"
    },
    "J": {
      "field_name": null,
      "column_header": "Tingkat Perkembangan",
      "transform": "constant",
      "value": "baru",
      "description": "Status tingkat perkembangan dokumen"
    },
    "K": {
      "field_name": null,
      "column_header": "Keterangan",
      "transform": "empty",
      "description": "Kolom keterangan (saat ini kosong)"
    },
    "L": {
      "field_name": "klasifikasi",
      "column_header": "Klasifikasi",
      "transform": "direct",
      "description": "Kode klasifikasi belanja yang sudah diekstrak dari OCR (misal: 01/01/06/6112/EBA/522191)"
    },
    "M": {
      "field_name": null,
      "column_header": "Hak Akses",
      "transform": "empty",
      "description": "Hak akses arsip (saat ini kosong)"
    },
    "N": {
      "field_name": null,
      "column_header": "Akses Publik?",
      "transform": "constant",
      "value": "no",
      "description": "Apakah arsip dapat diakses publik"
    },
    "O": {
      "field_name": "satker",
      "column_header": "UNIT PENGOLAH",
      "transform": "truncate",
      "max_length": 30,
      "description": "Satuan kerja sebagai unit pengolah (dipotong 30 karakter)"
    }
  },

  "available_fields": {
    "doc_id": {
      "source": "filename",
      "type": "string",
      "description": "ID dokumen dari nama file PNG tanpa ekstensi"
    },
    "filename": {
      "source": "file_system",
      "type": "string",
      "description": "Nama file asli PNG"
    },
    "doc_type": {
      "source": "ocr_parse",
      "type": "enum",
      "values": ["SPP", "SPTJB", "UNKNOWN"],
      "description": "Jenis dokumen berdasarkan pola OCR"
    },
    "nomor_surat": {
      "source": "ocr_parse",
      "type": "string",
      "description": "Nomor surat dari dokumen"
    },
    "uraian": {
      "source": "ocr_parse",
      "type": "string",
      "description": "Uraian/judul lengkap dokumen (misal: SURAT PERNYATAAN TANGGUNG JAWAB BELANJA)"
    },
    "klasifikasi": {
      "source": "ocr_parse",
      "type": "string",
      "description": "Kode klasifikasi belanja (misal: 01/01/06/6112/EBA/522191)"
    },
    "satker": {
      "source": "ocr_parse",
      "type": "string",
      "description": "Satuan kerja lengkap (DITJEN BINA BANGDA KEMENTERIAN DALAM NEGERI)"
    },
    "extraction_date": {
      "source": "system",
      "type": "datetime",
      "format": "ISO 8601",
      "description": "Tanggal dan waktu ekstraksi"
    },
    "items_count": {
      "source": "ocr_parse",
      "type": "integer",
      "description": "Jumlah item yang mengandung nilai uang"
    },
    "raw_ocr_full": {
      "source": "ocr_output",
      "type": "string",
      "description": "Hasil OCR penuh dari gambar (tanpa limit)"
    },
    "raw_ocr_snippet": {
      "source": "ocr_output",
      "type": "string",
      "max_length": 500,
      "description": "Cuplikan 500 karakter pertama dari hasil OCR"
    },
    "items": {
      "source": "ocr_parse",
      "type": "array",
      "description": "Daftar baris yang mengandung nilai uang"
    }
  },

  "transform_rules": {
    "direct": "Ambil nilai field langsung tanpa perubahan",
    "empty": "Isi dengan string kosong",
    "constant": "Isi dengan nilai konstan yang ditentukan",
    "concat": "Gabungkan beberapa field dengan separator",
    "truncate": "Potong string ke panjang maksimum",
    "date_format": "Format tanggal sesuai pattern Python strftime",
    "extract": "Ekstrak informasi menggunakan regex pattern"
  }
