[wsl2]
# ============================================
# WSL Always-On Server Configuration
# ============================================
# Copy file ini ke: C:\Users\<username>\.wslconfig
# Lalu jalankan: wsl --shutdown
# WSL akan otomatis restart dengan konfigurasi baru
# ============================================

# Resource allocation
memory=8GB
processors=4
swap=2GB
swapFile=C:\\temp\\wsl-swap.vhdx

# Network
localhostForwarding=true
networkingMode=mirrored
dnsTunneling=true
firewall=true
autoProxy=true

# Kernel flags untuk stabilitas
kernelCommandLine = cgroup_memory=1 cgroup_enable=memory clocksource=tsc

# Mencegah WSL shutdown saat idle
autoMemoryReclaim=gradual

# Disk optimization
sparseVhd=true

[experimental]
# Mencegah auto-shutdown WSL (CRITICAL for always-on)
autoShutdown=false
